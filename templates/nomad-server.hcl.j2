# {{ ansible_managed }}
# Nomad server configuration for {{ inventory_hostname }}.

datacenter = "{{ nomad_datacenter }}"
region     = "{{ nomad_region }}"
data_dir   = "{{ nomad_data_dir }}"
log_level  = "{{ nomad_log_level }}"

bind_addr = "{{ nomad_bind_addr }}"

advertise {
  http = "{{ nomad_advertise_addr }}"
  rpc  = "{{ nomad_advertise_addr }}"
  serf = "{{ nomad_advertise_addr }}"
}

ports {
  http = {{ nomad_http_port }}
  rpc  = {{ nomad_rpc_port }}
  serf = {{ nomad_serf_port }}
}

server {
  enabled          = true
  bootstrap_expect = {{ nomad_server_bootstrap_expect }}

  server_join {
    retry_join     = {{ nomad_servers | to_json }}
    retry_max      = 0
    retry_interval = "15s"
  }
}

{% if nomad_enable_acl %}
acl {
  enabled = true
}
{% endif %}
